{
  "name": "@arcjet/guard",
  "version": "0.1.0",
  "description": "Arcjet Guards SDK — AI guardrails for rate limiting, prompt injection detection, and sensitive info detection",
  "homepage": "https://arcjet.com",
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "arcjet-guard"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": {
        "types": "./dist/src/node.d.ts",
        "import": "./dist/src/node.js"
      },
      "edge-light": {
        "types": "./dist/src/fetch.d.ts",
        "import": "./dist/src/fetch.js"
      },
      "workerd": {
        "types": "./dist/src/fetch.d.ts",
        "import": "./dist/src/fetch.js"
      },
      "node": {
        "types": "./dist/src/node.d.ts",
        "import": "./dist/src/node.js"
      },
      "default": {
        "types": "./dist/src/fetch.d.ts",
        "import": "./dist/src/fetch.js"
      }
    },
    "./node": {
      "types": "./dist/src/node.d.ts",
      "import": "./dist/src/node.js"
    },
    "./fetch": {
      "types": "./dist/src/fetch.d.ts",
      "import": "./dist/src/fetch.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c rolldown.config.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "format": "oxfmt src/ test/",
    "format:check": "oxfmt --check src/ test/",
    "test": "npm run build && npm run lint && npm run test-unit",
    "test-unit": "node --test --experimental-test-coverage --test-coverage-include=src/** --test-coverage-exclude=src/**/*.test.ts src/**/*.test.ts",
    "test-runtime-node": "npm run build && node --test test/runtime/node.test.ts",
    "test-runtime-fetch": "npm run build && node --test test/runtime/fetch.test.ts",
    "test-runtime-deno": "npm run build && deno test --no-check --allow-all test/runtime/deno.test.ts",
    "test-runtime-bun": "npm run build && bun test test/runtime/bun.test.ts",
    "test-runtime-cloudflare": "npm run build && node --test test/runtime/cloudflare/cloudflare.test.ts",
    "test-runtime": "npm run build && node --test test/runtime/node.test.ts test/runtime/fetch.test.ts test/runtime/cloudflare/cloudflare.test.ts"
  },
  "dependencies": {
    "@arcjet/analyze": "1.3.0",
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@typescript/native-preview": "7.0.0-dev.20260326.1",
    "miniflare": "4.20260317.2",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.4",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
