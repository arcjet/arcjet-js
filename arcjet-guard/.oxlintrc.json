{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true
  },
  "plugins": ["typescript", "unicorn", "oxc", "import", "node", "promise"],
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "suspicious": "error"
  },
  "rules": {
    "eslint/max-lines-per-function": "off",
    "eslint/max-lines": "off",
    "eslint/no-inline-comments": "off",
    "eslint/no-promise-executor-return": "off",
    "eslint/no-warning-comments": "off",
    "typescript/explicit-function-return-type": "error",
    "typescript/no-floating-promises": [
      "error",
      {
        "allowForKnownSafeCalls": [
          {
            "from": "package",
            "name": [
              "after",
              "afterEach",
              "before",
              "beforeEach",
              "describe",
              "it",
              "suite",
              "test"
            ],
            "package": "node:test"
          }
        ]
      }
    ],
    "typescript/no-unsafe-type-assertion": "error",
    // TODO: Rules below were newly enforced by oxlint 1.70 (clean under 1.58)
    // and produce ~280 stylistic detections, none of which are bugs. Disabled
    // to take the linter bump now; adopting them needs deliberate code changes.
    // See tracking issue.
    "typescript/prefer-readonly-parameter-types": "off",
    "typescript/consistent-return": "off",
    "typescript/strict-void-return": "off",
    "typescript/no-unnecessary-type-parameters": "off",
    "eslint/require-unicode-regexp": "off",
    "eslint/no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["test/runtime/deno.test.ts", "test/runtime/bun.test.ts"],
      "rules": {
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "typescript/strict-boolean-expressions": "off"
      }
    }
  ],
  "ignorePatterns": ["examples/**"]
}
