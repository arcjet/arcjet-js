{
  "name": "@arcjet/sveltekit",
  "version": "1.3.1",
  "description": "Arcjet runtime security SDK for SvelteKit — bot protection, rate limiting, prompt injection detection, PII blocking, and WAF",
  "keywords": [
    "ai",
    "analyze",
    "arcjet",
    "attack",
    "bot-detection",
    "limit",
    "llm",
    "pii",
    "prompt-injection",
    "protect",
    "rate-limiting",
    "secure",
    "security",
    "svelte",
    "sveltekit",
    "verify",
    "waf"
  ],
  "license": "Apache-2.0",
  "homepage": "https://arcjet.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "arcjet-sveltekit"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "test": "npm run build && npm run lint && npm run typecheck",
    "typecheck": "tsgo --noEmit && tsgo --project tsconfig.lint.json --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@arcjet/body": "1.3.1",
    "@arcjet/env": "1.3.1",
    "@arcjet/headers": "1.3.1",
    "@arcjet/ip": "1.3.1",
    "@arcjet/logger": "1.3.1",
    "@arcjet/protocol": "1.3.1",
    "@arcjet/transport": "1.3.1",
    "arcjet": "1.3.1"
  },
  "peerDependencies": {
    "svelte": "^3.54.0 || ^4.0.0 || ^5.0.0-0"
  },
  "devDependencies": {
    "@types/node": "24.11.0",
    "@typescript/native-preview": "7.0.0-dev.20260331.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
