{
  "name": "@arcjet/sveltekit",
  "version": "1.5.0",
  "description": "Arcjet runtime security SDK for SvelteKit — bot protection, rate limiting, prompt injection detection, PII blocking, and WAF",
  "keywords": [
    "ai",
    "analyze",
    "arcjet",
    "attack",
    "bot-detection",
    "limit",
    "llm",
    "pii",
    "prompt-injection",
    "protect",
    "rate-limiting",
    "secure",
    "security",
    "svelte",
    "sveltekit",
    "verify",
    "waf"
  ],
  "homepage": "https://arcjet.com",
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "arcjet-sveltekit"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "npm run build"
  },
  "dependencies": {
    "@arcjet/body": "1.5.0",
    "@arcjet/env": "1.5.0",
    "@arcjet/headers": "1.5.0",
    "@arcjet/ip": "1.5.0",
    "@arcjet/logger": "1.5.0",
    "@arcjet/protocol": "1.5.0",
    "@arcjet/transport": "1.5.0",
    "arcjet": "1.5.0"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "svelte": "^3.54.0 || ^4.0.0 || ^5.0.0-0"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  }
}
