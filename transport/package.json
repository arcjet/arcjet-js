{
  "name": "@arcjet/transport",
  "version": "1.6.1",
  "description": "Transport mechanisms for the Arcjet protocol",
  "keywords": [
    "arcjet",
    "transport",
    "utility",
    "util"
  ],
  "license": "Apache-2.0",
  "homepage": "https://arcjet.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "transport"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    "bun": "./bun.js",
    "deno": "./deno.js",
    "edge-light": "./edge-light.js",
    "workerd": "./workerd.js",
    "default": "./index.js"
  },
  "files": [
    "bun.d.ts",
    "bun.js",
    "deno.d.ts",
    "deno.js",
    "detect-proxy.d.ts",
    "detect-proxy.js",
    "edge-light.d.ts",
    "edge-light.js",
    "index.d.ts",
    "index.js",
    "proxy-tunnel.d.ts",
    "proxy-tunnel.js",
    "workerd.d.ts",
    "workerd.js"
  ],
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "lint": "eslint .",
    "test-api": "node --test -- test/*.test.js",
    "test-coverage": "node --experimental-test-coverage --test -- test/*.test.js",
    "test-runtime-bun": "npm run build && HTTPS_PROXY=http://127.0.0.1:49219 bun test test/runtime/proxy.bun.test.ts",
    "test-runtime-deno": "npm run build && HTTPS_PROXY=http://127.0.0.1:49219 deno test --allow-all --no-check test/runtime/proxy.deno.test.ts",
    "test": "npm run build && npm run lint && npm run test-coverage"
  },
  "dependencies": {
    "@arcjet/env": "1.6.1",
    "@arcjet/logger": "1.6.1",
    "@bufbuild/protobuf": "2.12.0",
    "@connectrpc/connect": "2.1.2",
    "@connectrpc/connect-node": "2.1.2",
    "@connectrpc/connect-web": "2.1.2"
  },
  "devDependencies": {
    "@arcjet/eslint-config": "1.6.1",
    "@arcjet/rollup-config": "1.6.1",
    "@rollup/wasm-node": "4.62.2",
    "@types/node": "22.19.21",
    "eslint": "9.39.4",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
