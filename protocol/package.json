{
  "name": "@arcjet/protocol",
  "version": "1.3.1",
  "description": "The TypeScript & JavaScript interface into the Arcjet protocol",
  "keywords": [
    "arcjet",
    "utility",
    "util",
    "protocol"
  ],
  "license": "Apache-2.0",
  "homepage": "https://arcjet.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "protocol"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "proto/",
    "client.d.ts",
    "client.js",
    "convert.d.ts",
    "convert.js",
    "index.d.ts",
    "index.js",
    "well-known-bots.d.ts",
    "well-known-bots.js"
  ],
  "scripts": {
    "build": "rm -f *.js *.d.ts test/*.js test/*.d.ts && rolldown -c rolldown.config.ts",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "test-api": "node --test -- test/*.test.js",
    "test-coverage": "node --experimental-test-coverage --test -- test/*.test.js",
    "test": "npm run build && npm run lint && npm run typecheck && npm run test-coverage",
    "typecheck": "tsgo --noEmit && tsgo --project tsconfig.lint.json --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@arcjet/cache": "1.3.1",
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "typeid-js": "1.2.0"
  },
  "devDependencies": {
    "@types/node": "24.11.0",
    "@typescript/native-preview": "7.0.0-dev.20260331.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
