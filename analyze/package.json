{
  "name": "@arcjet/analyze",
  "version": "1.9.2",
  "description": "Arcjet local analysis engine",
  "keywords": [
    "analyze",
    "arcjet",
    "attack",
    "limit",
    "protect",
    "verify"
  ],
  "homepage": "https://arcjet.com",
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "analyze"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test-api": "node --test -- test/*.test.ts",
    "test-coverage": "node --experimental-test-coverage --test -- test/*.test.ts",
    "test": "npm run build && npm run test-coverage"
  },
  "dependencies": {
    "@arcjet/analyze-wasm": "1.9.2",
    "@arcjet/protocol": "1.9.2"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "1.5.0",
    "@types/node": "22.20.1",
    "tsdown": "0.22.7",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  }
}
