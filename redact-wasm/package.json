{
  "name": "@arcjet/redact-wasm",
  "version": "1.3.1",
  "description": "Arcjet sensitive information redaction detection engine",
  "keywords": [
    "arcjet",
    "redact",
    "utility",
    "util",
    "wasm"
  ],
  "license": "Apache-2.0",
  "homepage": "https://arcjet.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "redact-wasm"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    "edge-light": "./edge-light.js",
    "workerd": "./workerd.js",
    "default": "./index.js"
  },
  "files": [
    "_virtual/",
    "wasm/",
    "edge-light.d.ts",
    "edge-light.js",
    "index.d.ts",
    "index.js",
    "workerd.d.ts",
    "workerd.js"
  ],
  "scripts": {
    "build:jco": "jco transpile --instantiation async --no-wasi-shim --out-dir wasm/ -- wasm/arcjet_analyze_bindings_redact.component.wasm",
    "build": "npm run build:jco && npm run build:rolldown",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "test-api": "node --test -- test/*.test.js",
    "test-coverage": "node --experimental-test-coverage --test -- test/*.test.js",
    "test": "npm run build && npm run lint && npm run typecheck && npm run test-coverage",
    "build:rolldown": "rm -rf _virtual/ && rm -f *.js && find . -maxdepth 1 -name '*.d.ts' ! -name 'wasm.d.ts' -delete && rm -f test/*.js test/*.d.ts && rolldown -c rolldown.config.ts",
    "typecheck": "tsgo --noEmit && tsgo --project tsconfig.lint.json --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {},
  "devDependencies": {
    "@bytecodealliance/jco": "1.5.0",
    "@types/node": "24.11.0",
    "@typescript/native-preview": "7.0.0-dev.20260331.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
