{
  "name": "@arcjet/redact-wasm",
  "version": "1.6.1",
  "description": "Arcjet sensitive information redaction detection engine",
  "keywords": [
    "arcjet",
    "redact",
    "util",
    "utility",
    "wasm"
  ],
  "homepage": "https://arcjet.com",
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "redact-wasm"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "edge-light": {
        "types": "./dist/edge-light.d.ts",
        "default": "./dist/edge-light.js"
      },
      "workerd": {
        "types": "./dist/workerd.d.ts",
        "default": "./dist/workerd.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build:jco": "jco transpile --instantiation async --no-wasi-shim --out-dir src/wasm/ -- src/wasm/arcjet_analyze_bindings_redact.component.wasm",
    "build": "npm run build:jco && tsdown",
    "test-api": "node --test -- test/*.test.ts",
    "test-coverage": "node --experimental-test-coverage --test -- test/*.test.ts",
    "test": "npm run build && npm run test-coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "@bytecodealliance/jco": "1.5.0",
    "@types/node": "22.19.21",
    "tsdown": "0.22.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  }
}
