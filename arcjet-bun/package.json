    "directory": "arcjet-bun"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {},
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "build": "rm -f *.js *.d.ts test/*.js test/*.d.ts && rolldown -c rolldown.config.ts",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "test": "npm run build && npm run lint && npm run typecheck",
    "typecheck": "tsgo --noEmit && tsgo --project tsconfig.lint.json --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@arcjet/body": "1.3.1",
    "@arcjet/env": "1.3.1",
    "@arcjet/headers": "1.3.1",
    "@arcjet/ip": "1.3.1",
    "@arcjet/logger": "1.3.1",
    "@arcjet/protocol": "1.3.1",
    "@arcjet/transport": "1.3.1",
    "arcjet": "1.3.1"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260331.1",
    "bun-types": "1.3.10",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2",
    "undici-types": "7.22.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
