{
  "name": "@arcjet/runtime",
  "version": "1.3.1",
  "description": "Arcjet runtime detection",
  "keywords": [
    "arcjet",
    "detect",
    "runtime",
    "utility",
    "util"
  ],
  "license": "Apache-2.0",
  "homepage": "https://arcjet.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "runtime"
  },
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    "edge-light": "./edge-light.js",
    "default": "./index.js"
  },
  "files": [
    "edge-light.d.ts",
    "edge-light.js",
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "build": "rm -f *.js *.d.ts test/*.js test/*.d.ts && rolldown -c rolldown.config.ts",
    "lint": "oxlint --tsconfig=tsconfig.lint.json",
    "test-api": "node --experimental-vm-modules --test -- test/*.test.js",
    "test-coverage": "node --experimental-test-coverage --experimental-vm-modules --test -- test/*.test.js",
    "test": "npm run build && npm run lint && npm run typecheck && npm run test-coverage",
    "typecheck": "tsgo --noEmit && tsgo --project tsconfig.lint.json --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260331.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
