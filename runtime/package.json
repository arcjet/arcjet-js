{
  "name": "@arcjet/runtime",
  "version": "1.6.1",
  "description": "Arcjet runtime detection",
  "keywords": [
    "arcjet",
    "detect",
    "runtime",
    "util",
    "utility"
  ],
  "homepage": "https://arcjet.com",
  "bugs": {
    "url": "https://github.com/arcjet/arcjet-js/issues",
    "email": "support@arcjet.com"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Arcjet",
    "email": "support@arcjet.com",
    "url": "https://arcjet.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arcjet/arcjet-js.git",
    "directory": "runtime"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "edge-light": {
        "types": "./dist/edge-light.d.ts",
        "default": "./dist/edge-light.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test-api": "node --experimental-vm-modules --test -- test/*.test.ts",
    "test-coverage": "node --experimental-test-coverage --experimental-vm-modules --test -- test/*.test.ts",
    "test": "npm run build && npm run test-coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  }
}
