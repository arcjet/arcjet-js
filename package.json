{
  "name": "arcjet-js",
  "version": "1.7.0",
  "private": true,
  "workspaces": [
    "*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "oxlint --disable-nested-config",
    "test-api": "turbo run test-api",
    "test-coverage": "turbo run test-coverage",
    "test": "turbo test",
    "format": "oxfmt --disable-nested-config",
    "format:check": "oxfmt --disable-nested-config --check"
  },
  "devDependencies": {
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "turbo": "2.9.18"
  },
  "overrides": {
    "@bufbuild/protobuf": "2.12.0",
    "@sveltejs/kit": {
      "cookie": "0.7.2"
    },
    "postcss": "^8.5.10",
    "rollup": "npm:@rollup/wasm-node"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0"
  },
  "packageManager": "npm@11.11.0"
}
