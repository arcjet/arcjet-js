{
  "name": "arcjet-js",
  "version": "1.9.1",
  "private": true,
  "workspaces": [
    "*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "oxlint --disable-nested-config",
    "test-api": "turbo run test-api",
    "test-coverage": "turbo run test-coverage",
    "test": "turbo test",
    "format": "oxfmt --disable-nested-config",
    "format:check": "oxfmt --disable-nested-config --check",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "turbo": "2.10.5"
  },
  "overrides": {
    "@bufbuild/protobuf": "2.12.1",
    "@sveltejs/kit": {
      "cookie": "0.7.2"
    },
    "fast-uri": "3.1.4",
    "postcss": "^8.5.10",
    "rolldown-plugin-dts": {
      "typescript": "7.0.2"
    },
    "rollup": "npm:@rollup/wasm-node",
    "svgo": "4.0.2"
  },
  "engines": {
    "node": ">=22.21.0 <23 || >=24.5.0",
    "npm": "^12.0.0"
  },
  "packageManager": "npm@12.0.1",
  "allowScripts": {
    "esbuild": false,
    "fsevents": false,
    "onnxruntime-node": false,
    "protobufjs": false,
    "sharp": false,
    "workerd": false
  }
}
